# ===================================================================
# UBAX Platform – Variables d'environnement PRODUCTION
# ===================================================================
# ⚠️  Ce fichier est un TEMPLATE. Copiez-le sur le VPS :
#       cp .env.prod.example /opt/ubax/.env
#     et remplissez TOUTES les valeurs avant de démarrer.
#
# ⛔  Ne jamais committer le fichier .env réel dans Git !
# ===================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=ubax
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD
POSTGRES_DB=db-ubax

# ─── Keycloak ─────────────────────────────────────────────────────
VPS_IP=CHANGEME_VPS_IP
KEYCLOAK_DB_NAME=db-keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGEME_KEYCLOAK_ADMIN
KEYCLOAK_REALM=CHANGEME_REALM
KEYCLOAK_CLIENT_ID=CHANGEME_CLIENT_ID
KEYCLOAK_CLIENT_SECRET=CHANGEME_CLIENT_SECRET

# ─── pgAdmin ──────────────────────────────────────────────────────
PGADMIN_EMAIL=CHANGEME_EMAIL
PGADMIN_PASSWORD=CHANGEME_PGADMIN_PASSWORD

# ─── MinIO ────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGEME_MINIO_PASSWORD

# ─── Backend ──────────────────────────────────────────────────────
# Tag de l'image Docker Hub (latest = branche main, develop = branche develop)
BACKEND_TAG=latest
ADMIN_EMAIL=CHANGEME_ADMIN_EMAIL

# ─── Mail SMTP ────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGEME_MAIL_USERNAME
MAIL_PASSWORD=CHANGEME_MAIL_APP_PASSWORD
MAIL_FROM=CHANGEME_MAIL_FROM
MAIL_FROM_NAME=UBAX Platform

# ─── SMS – LAfricaMobile (LAMPUSH) ────────────────────────────────
LAM_SMS_URL=https://lamsms.lafricamobile.com/api
LAM_ACCOUNT_ID=CHANGEME_LAM_ACCOUNT_ID
LAM_PASSWORD=CHANGEME_LAM_PASSWORD
LAM_SENDER=CHANGEME_LAM_SENDER

# ─── Bootstrap Super Admin ───────────────────────────────────────
# Activer UNIQUEMENT au premier déploiement (DB vierge).
# Un email de définition du mot de passe sera envoyé à BOOTSTRAP_SUPER_ADMIN_EMAIL.
# Repasser à false après la première connexion.
BOOTSTRAP_ENABLED=false
BOOTSTRAP_SUPER_ADMIN_EMAIL=CHANGEME_SUPER_ADMIN_EMAIL
BOOTSTRAP_SUPER_ADMIN_FIRST_NAME=Super
BOOTSTRAP_SUPER_ADMIN_LAST_NAME=Admin
BOOTSTRAP_SUPER_ADMIN_PHONE=CHANGEME_PHONE

# ─── Frontends ────────────────────────────────────────────────────
ADMIN_TAG=latest
PORTAIL_TAG=latest
